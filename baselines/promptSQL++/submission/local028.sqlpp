SELECT
    DATE_PART_STR(o.order_delivered_customer_date, 'month') AS month,
    COUNT(CASE WHEN DATE_PART_STR(o.order_delivered_customer_date, 'year') = 2016 THEN 1 END) AS `2016`,
    COUNT(CASE WHEN DATE_PART_STR(o.order_delivered_customer_date, 'year') = 2017 THEN 1 END) AS `2017`,
    COUNT(CASE WHEN DATE_PART_STR(o.order_delivered_customer_date, 'year') = 2018 THEN 1 END) AS `2018`
FROM `brazilian_e_commerce`.`brazilian_e_commerce_scope`.`olist_orders` AS o
WHERE o.order_status = 'delivered'
  AND DATE_PART_STR(o.order_delivered_customer_date, 'year') IN [2016, 2017, 2018]
GROUP BY month
ORDER BY month;