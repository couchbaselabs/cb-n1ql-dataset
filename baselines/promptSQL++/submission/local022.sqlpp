SELECT DISTINCT p.player_name
FROM `ipl`.`ipl_scope`.`batsman_scored` AS bs
JOIN `ipl`.`ipl_scope`.`match` AS m
  ON bs.match_id = m.match_id
JOIN `ipl`.`ipl_scope`.`player_match` AS pm
  ON bs.match_id = pm.match_id
JOIN `ipl`.`ipl_scope`.`player` AS p
  ON pm.player_id = p.player_id
WHERE pm.team_id = m.match_winner
  AND m.match_winner != pm.team_id
GROUP BY p.player_id, p.player_name, bs.match_id
HAVING SUM(bs.runs_scored) >= 100;