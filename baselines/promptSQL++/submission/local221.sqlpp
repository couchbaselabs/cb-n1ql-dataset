SELECT
    t.team_long_name,
    COUNT(1) AS wins
FROM `eu_soccer`.`eu_soccer_scope`.`Match` AS m
JOIN `eu_soccer`.`eu_soccer_scope`.`Team` AS t
    ON (m.home_team_api_id = t.team_api_id AND m.home_team_goal > m.away_team_goal)
    OR (m.away_team_api_id = t.team_api_id AND m.away_team_goal > m.home_team_goal)
GROUP BY t.team_long_name
ORDER BY wins DESC
LIMIT 10;