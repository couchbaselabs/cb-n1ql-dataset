SELECT
    t.topping_name,
    SUM(CAST(TRIM(tid) AS INT)) AS total_quantity
FROM `modern_data`.`modern_data_scope`.`pizza_clean_customer_orders` AS o
JOIN `modern_data`.`modern_data_scope`.`pizza_recipes` AS r
    ON o.pizza_id = r.pizza_id
UNNEST SPLIT(r.toppings, ',') AS tid
JOIN `modern_data`.`modern_data_scope`.`pizza_toppings` AS t
    ON CAST(TRIM(tid) AS INT) = t.topping_id
GROUP BY t.topping_name;