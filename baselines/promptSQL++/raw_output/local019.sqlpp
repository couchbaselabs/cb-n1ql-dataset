SELECT
    w1.name AS wrestler1,
    w2.name AS wrestler2
FROM `wwe`.`wwe_scope`.`Matches` AS m
JOIN `wwe`.`wwe_scope`.`Belts` AS b
    ON m.title_id = TO_STRING(b.id)
JOIN `wwe`.`wwe_scope`.`Wrestlers` AS w1
    ON m.winner_id = TO_STRING(w1.id)
JOIN `wwe`.`wwe_scope`.`Wrestlers` AS w2
    ON m.loser_id = TO_STRING(w2.id)
WHERE b.name LIKE 'NXT%'
  AND m.title_change = 0
ORDER BY
  (CAST(SUBSTR(m.duration, 1, 2) AS INT) * 60 + CAST(SUBSTR(m.duration, 4, 2) AS INT)) ASC
LIMIT 1;