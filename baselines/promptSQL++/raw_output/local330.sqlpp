WITH session_pages AS (
  SELECT
    a.session,
    FIRST_VALUE(a.path) OVER (PARTITION BY a.session ORDER BY a.stamp ASC) AS landing_page,
    FIRST_VALUE(a.path) OVER (PARTITION BY a.session ORDER BY a.stamp DESC) AS exit_page
  FROM `log`.`log_scope`.`activity_log` AS a
)
SELECT
  page,
  COUNT(DISTINCT session) AS unique_session_count
FROM (
  SELECT session, landing_page AS page FROM session_pages
  UNION ALL
  SELECT session, exit_page AS page FROM session_pages
) AS pages
GROUP BY page;