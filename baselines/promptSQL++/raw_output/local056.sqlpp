SELECT
    CONCAT(c.first_name, ' ', c.last_name) AS full_name
FROM `sqlite_sakila`.`sqlite_sakila_scope`.`payment` AS p
JOIN `sqlite_sakila`.`sqlite_sakila_scope`.`customer` AS c
    ON p.customer_id = c.customer_id
GROUP BY c.customer_id, c.first_name, c.last_name
ORDER BY 
    MAX(p.payment_date) - MIN(p.payment_date) = 0 
    OR (SUM(p.amount) / (DATE_DIFF_STR(MAX(p.payment_date), MIN(p.payment_date), 'month') + 1)) DESC
LIMIT 1;