SELECT
    t.boroname,
    COUNT(t.tree_id) AS tree_count,
    AVG(i.Estimate_Mean_income) AS avg_mean_income
FROM `modern_data`.`modern_data_scope`.`trees` AS t
LEFT JOIN `modern_data`.`modern_data_scope`.`income_trees` AS i
    ON t.zipcode = i.zipcode
WHERE t.boroname IS NOT NULL
  AND t.boroname != ''
  AND i.Estimate_Median_income > 0
  AND i.Estimate_Mean_income > 0
GROUP BY t.boroname
ORDER BY tree_count DESC
LIMIT 3;