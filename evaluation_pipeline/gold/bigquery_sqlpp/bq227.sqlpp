WITH aggregated AS (
  SELECT
    c.year,
    c.minor_category,
    SUM(c.`value`) AS total
  FROM london.london_crime.crime_by_lsoa c
  GROUP BY c.year, c.minor_category
),

top5_2008 AS (
  SELECT a.minor_category
  FROM aggregated a
  WHERE a.year = 2008
  ORDER BY a.total DESC
  LIMIT 5
),

yearly_totals AS (
  SELECT year, SUM(total) AS year_total
  FROM aggregated
  GROUP BY year
)

SELECT 
  a.year,

  ROUND(MAX(CASE WHEN a.minor_category = 'Other Theft' THEN (a.total * 100.0 / yt.year_total) END), 2) AS `Other Theft`,
  ROUND(MAX(CASE WHEN a.minor_category = 'Theft From Motor Vehicle' THEN (a.total * 100.0 / yt.year_total) END), 2) AS `Theft From Motor Vehicle`,
  ROUND(MAX(CASE WHEN a.minor_category = 'Possession Of Drugs' THEN (a.total * 100.0 / yt.year_total) END), 2) AS `Possession Of Drugs`,
  ROUND(MAX(CASE WHEN a.minor_category = 'Burglary in a Dwelling' THEN (a.total * 100.0 / yt.year_total) END), 2) AS `Burglary in a Dwelling`,
  ROUND(MAX(CASE WHEN a.minor_category = 'Assault with Injury' THEN (a.total * 100.0 / yt.year_total) END), 2) AS `Assault with Injury`

FROM aggregated a
JOIN top5_2008 t ON a.minor_category = t.minor_category
JOIN yearly_totals yt ON a.year = yt.year

GROUP BY a.year
ORDER BY a.year;