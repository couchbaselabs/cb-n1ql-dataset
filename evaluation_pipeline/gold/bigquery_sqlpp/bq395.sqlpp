WITH homeless_2015 AS (
    SELECT 
        SUBSTR(h.CoC_Number, 0, 2) AS State_Abbr,
        IFMISSINGORNULL(h.Unsheltered_Homeless, 0) AS U15
    FROM `sdoh`.`sdoh_hud_pit_homelessness`.`hud_pit_by_coc` AS h
    WHERE h.Count_Year = 2015
),

homeless_2018 AS (
    SELECT 
        SUBSTR(h.CoC_Number, 0, 2) AS State_Abbr,
        IFMISSINGORNULL(h.Unsheltered_Homeless, 0) AS U18
    FROM `sdoh`.`sdoh_hud_pit_homelessness`.`hud_pit_by_coc` AS h
    WHERE h.Count_Year = 2018
),

unsheltered_change AS (
    SELECT 
        h18.State_Abbr,
        SUM(h15.U15) AS Unsheltered_2015,
        SUM(h18.U18) AS Unsheltered_2018,
        (SUM(h18.U18) - SUM(h15.U15)) * 100.0 / SUM(h15.U15) AS Percent_Change
    FROM homeless_2018 AS h18
    JOIN homeless_2015 AS h15
    ON h18.State_Abbr = h15.State_Abbr
    GROUP BY h18.State_Abbr
),

average_change AS (
    SELECT AVG(u.Percent_Change) AS Avg_Change
    FROM unsheltered_change AS u
)

SELECT u.State_Abbr
FROM unsheltered_change AS u, average_change AS a
ORDER BY ABS(u.Percent_Change - a.Avg_Change)
LIMIT 5;