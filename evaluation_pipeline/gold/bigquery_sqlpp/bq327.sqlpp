WITH russia_data AS (
    SELECT DISTINCT
        id.country_name,
        id.`value`,
        id.indicator_name
    FROM world_bank.world_bank_intl_debt.country_summary cs
    JOIN world_bank.world_bank_intl_debt.international_debt id
        ON cs.country_code = id.country_code
    WHERE cs.region != ""
        AND id.country_code = "RUS"
        AND id.`value` IS NOT NULL
)

SELECT 
    COUNT(*) AS number_of_indicators_with_zero
FROM russia_data
WHERE `value` = 0;