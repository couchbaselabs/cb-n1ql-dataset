WITH country_data AS (
    SELECT 
        cs.country_code,
        cs.short_name AS country,
        cs.region,
        cs.income_group
    FROM world_bank.world_bank_wdi.country_summary cs
),

gdp_data AS (
    SELECT 
        d.country_code,
        c.country,
        c.region,
        d.`value` AS gdp_value
    FROM world_bank.world_bank_wdi.indicators_data d
    LEFT JOIN country_data c
        ON d.country_code = c.country_code
    WHERE d.indicator_code = "NY.GDP.MKTP.KD"
        AND c.region IS NOT NULL
        AND c.income_group IS NOT NULL
        AND d.`value` IS NOT NULL
),

ranked AS (
    SELECT
        region,
        gdp_value,
        ROW_NUMBER() OVER (PARTITION BY region ORDER BY gdp_value) AS rn,
        COUNT(*) OVER (PARTITION BY region) AS cnt
    FROM gdp_data
),

median_calc AS (
    SELECT
        region,
        AVG(gdp_value) AS median_gdp
    FROM ranked
    WHERE rn IN [FLOOR((cnt + 1) / 2), FLOOR((cnt + 2) / 2)]
    GROUP BY region
)

SELECT region
FROM median_calc
ORDER BY median_gdp DESC
LIMIT 1;