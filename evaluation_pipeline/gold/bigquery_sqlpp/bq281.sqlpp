SELECT COUNT(1) AS num_rides
FROM austin.austin_bikeshare.bikeshare_trips t
WHERE t.start_station_name NOT IN ['Mobile Station', 'Repair Shop']
  AND t.end_station_name NOT IN ['Mobile Station', 'Repair Shop']
  AND t.subscriber_type = 'Student Membership'
  AND t.bike_type = 'electric'
  AND t.duration_minutes > 10
GROUP BY DATE_PART_STR(t.start_time, 'year'),
         DATE_PART_STR(t.start_time, 'month'),
         DATE_PART_STR(t.start_time, 'day')
ORDER BY num_rides DESC
LIMIT 1;
