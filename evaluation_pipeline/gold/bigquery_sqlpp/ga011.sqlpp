SELECT page_path, page_views FROM (
  SELECT
    page_path,
    COUNT(*) AS page_views,
    ROW_NUMBER() OVER (ORDER BY COUNT(*) DESC) AS rn
  FROM (
    SELECT
      REPLACE(
        REPLACE(
          SUBSTR(
            SPLIT(pl.`value`.string_value, "?")[0],
            LENGTH("https://shop.googlemerchandisestore.com")
          ),
          "//", "/"
        ),
        "//", "/"
      ) AS page_path
    FROM ga4.ga4_obfuscated_sample_ecommerce.events_202012 e
    UNNEST e.event_params AS pl
    WHERE e.event_name = "page_view"
      AND pl.`key` = "page_location"
      AND pl.`value`.string_value LIKE "https://shop.googlemerchandisestore.com%"
  ) cleaned
  WHERE page_path IS NOT NULL AND page_path != ""
  GROUP BY page_path
) ranked
WHERE rn = 2