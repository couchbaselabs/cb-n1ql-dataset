WITH unnested_events AS (
  SELECT
    e.event_timestamp AS ts,
    e.user_pseudo_id AS uid,
    (FIRST p.`value`.int_value FOR p IN e.event_params WHEN p.`key` = 'ga_session_id' END) AS sid,
    (FIRST p.`value`.string_value FOR p IN e.event_params WHEN p.`key` = 'page_title' END) AS page_title,
    (FIRST p.`value`.string_value FOR p IN e.event_params WHEN p.`key` = 'page_location' END) AS page_location
  FROM `ga4`.ga4_obfuscated_sample_ecommerce.events_202101 e
  WHERE e.event_date = '20210102'
    AND e.event_name = 'page_view'
),
categorised AS (
  SELECT unnested_events.*,
    CASE
      WHEN ARRAY_LENGTH(SPLIT(page_location, '/')) >= 5
           AND CONTAINS(ARRAY_REVERSE(SPLIT(page_location, '/'))[0], '+')
           AND (LOWER(SPLIT(page_location, '/')[4]) IN ['accessories','apparel','brands','campus+collection','drinkware','electronics','google+redesign','lifestyle','nest','new+2015+logo','notebooks+journals','office','shop+by+brand','small+goods','stationery','wearables']
                OR LOWER(SPLIT(page_location, '/')[3]) IN ['accessories','apparel','brands','campus+collection','drinkware','electronics','google+redesign','lifestyle','nest','new+2015+logo','notebooks+journals','office','shop+by+brand','small+goods','stationery','wearables'])
      THEN 'PDP'
      WHEN ARRAY_LENGTH(SPLIT(page_location, '/')) >= 5
           AND NOT CONTAINS(ARRAY_REVERSE(SPLIT(page_location, '/'))[0], '+')
           AND (LOWER(SPLIT(page_location, '/')[4]) IN ['accessories','apparel','brands','campus+collection','drinkware','electronics','google+redesign','lifestyle','nest','new+2015+logo','notebooks+journals','office','shop+by+brand','small+goods','stationery','wearables']
                OR LOWER(SPLIT(page_location, '/')[3]) IN ['accessories','apparel','brands','campus+collection','drinkware','electronics','google+redesign','lifestyle','nest','new+2015+logo','notebooks+journals','office','shop+by+brand','small+goods','stationery','wearables'])
      THEN 'PLP'
      ELSE page_title
    END AS page_type
  FROM unnested_events
),
plp_with_pdp AS (
  SELECT COUNT(*) AS cnt
  FROM categorised c1
  WHERE c1.page_type = 'PLP'
    AND EXISTS (
      SELECT 1 FROM categorised c2
      WHERE c2.uid = c1.uid AND c2.sid = c1.sid
        AND c2.ts > c1.ts AND c2.page_type = 'PDP'
    )
),
total_plp AS (
  SELECT COUNT(*) AS cnt
  FROM categorised
  WHERE page_type = 'PLP'
)
SELECT
  p.cnt AS plp_views_with_pdp_in_session,
  t.cnt AS total_plp_views,
  p.cnt * 100.0 / t.cnt AS plp_to_pdp_percentage
FROM plp_with_pdp p, total_plp t;
