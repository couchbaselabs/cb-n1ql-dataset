WITH Params AS (
    SELECT "Google Red Speckled Tee" AS selected_product
),

-- Step 1: Purchase events with period tagging
PurchaseEvents AS (
    SELECT "202011" AS period, T.user_pseudo_id, T.items
    FROM ga4.ga4_obfuscated_sample_ecommerce.events_202011 AS T
    WHERE T.event_name = "purchase"

    UNION ALL

    SELECT "202012" AS period, T.user_pseudo_id, T.items
    FROM ga4.ga4_obfuscated_sample_ecommerce.events_202012 AS T
    WHERE T.event_name = "purchase"

    UNION ALL

    SELECT "202101" AS period, T.user_pseudo_id, T.items
    FROM ga4.ga4_obfuscated_sample_ecommerce.events_202101 AS T
    WHERE T.event_name = "purchase"
),

-- Step 2: Users who bought the selected product (per period)
ProductABuyers AS (
    SELECT DISTINCT
        pe.period,
        pe.user_pseudo_id
    FROM PurchaseEvents AS pe
    UNNEST pe.items AS item
    WHERE item.item_name = (SELECT RAW selected_product FROM Params)[0]
),

-- Step 3: All other products bought by those users
TopProducts AS (
    SELECT
        pe.period,
        item.item_name AS item_name,
        SUM(item.quantity) AS item_quantity
    FROM PurchaseEvents AS pe
    UNNEST pe.items AS item
    WHERE pe.user_pseudo_id IN (
        SELECT RAW pb.user_pseudo_id
        FROM ProductABuyers pb
        WHERE pb.period = pe.period
    )
    AND item.item_name != (SELECT RAW selected_product FROM Params)[0]
    GROUP BY pe.period, item.item_name
),

-- Step 4: Rank per period
TopProductPerPeriod AS (
    SELECT
        period,
        item_name,
        item_quantity
    FROM (
        SELECT
            period,
            item_name,
            item_quantity,
            RANK() OVER (PARTITION BY period ORDER BY item_quantity DESC) AS rnk
        FROM TopProducts
    ) ranked
    WHERE rnk = 1
)

-- Final result
SELECT
    period,
    item_name,
    item_quantity
FROM TopProductPerPeriod
ORDER BY period;