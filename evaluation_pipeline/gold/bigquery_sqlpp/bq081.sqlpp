SELECT r.name AS REGION_NAME,
       latest.trip_id AS TRIP_ID,
       latest.duration_sec AS RIDE_DURATION,
       latest.start_date AS START_TIME,
       latest.start_station_name AS STARTING_STATION,
       latest.member_gender AS RIDER_GENDER
FROM san_francisco_plus.san_francisco_bikeshare.bikeshare_regions r
LET station_ids = (
      SELECT RAW s.station_id
      FROM san_francisco_plus.san_francisco_bikeshare.bikeshare_station_info s
      WHERE s.region_id = r.region_id
    ),
    latest = (
      SELECT t.trip_id, t.duration_sec, t.start_date, t.start_station_name, t.member_gender
      FROM san_francisco_plus.san_francisco_bikeshare.bikeshare_trips t
      WHERE TOSTRING(t.start_station_id) IN station_ids
        AND DATE_PART_STR(t.start_date, 'year') BETWEEN 2014 AND 2017
      ORDER BY t.start_date DESC
      LIMIT 1
    )[0]
WHERE r.name IS NOT NULL AND latest IS NOT NULL;
