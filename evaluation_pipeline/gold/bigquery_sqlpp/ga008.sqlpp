WITH UserInfo AS (
    SELECT
        T.user_pseudo_id,
        T.event_date,
        SUM(CASE WHEN T.event_name = "page_view" THEN 1 ELSE 0 END) AS page_view_count,
        SUM(CASE WHEN T.event_name = "purchase" THEN 1 ELSE 0 END) AS purchase_event_count
    FROM ga4.ga4_obfuscated_sample_ecommerce.events_202011 AS T
    GROUP BY T.user_pseudo_id, T.event_date
)

SELECT
    event_date,
    SUM(page_view_count) / COUNT(*) AS avg_page_views,
    SUM(page_view_count) AS total_page_views
FROM UserInfo
WHERE purchase_event_count > 0
GROUP BY event_date
ORDER BY event_date;