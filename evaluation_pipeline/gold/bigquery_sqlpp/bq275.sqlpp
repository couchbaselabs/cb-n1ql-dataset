WITH visit AS (
    SELECT s.fullVisitorId AS fullVisitorId,
           MIN(s.date) AS date_first_visit
    FROM (
        SELECT fullVisitorId, date FROM ga360.google_analytics_sample.ga_sessions_201608
        
    ) AS s
    GROUP BY s.fullVisitorId
),

transactions AS (
    SELECT s.fullVisitorId AS fullVisitorId,
           MIN(s.date) AS date_transactions
    FROM (
        SELECT fullVisitorId, date, hits FROM ga360.google_analytics_sample.ga_sessions_201608
        
    ) AS s
    UNNEST s.hits AS h
    WHERE h.`transaction`.transactionId IS NOT NULL
    GROUP BY s.fullVisitorId
),

device_transactions AS (
    SELECT DISTINCT s.fullVisitorId AS fullVisitorId,
           s.date AS date,
           s.device.deviceCategory AS device_transaction
    FROM (
        SELECT fullVisitorId, date, device, hits FROM ga360.google_analytics_sample.ga_sessions_201608
        
    ) AS s
    UNNEST s.hits AS h
    WHERE h.`transaction`.transactionId IS NOT NULL
)

SELECT v.fullVisitorId
FROM visit v
JOIN transactions t
    ON v.fullVisitorId = t.fullVisitorId
JOIN device_transactions d
    ON v.fullVisitorId = d.fullVisitorId
   AND t.date_transactions = d.date
WHERE t.date_transactions > v.date_first_visit
  AND d.device_transaction = "mobile";