SELECT 'BLS - Computer systems design and related services' AS source,
       c.percent_asian AS asian,
       c.percent_black_or_african_american AS black,
       c.percent_hispanic_or_latino AS hispanic_latinx,
       c.percent_white AS white,
       c.percent_women AS us_women,
       ROUND(1 - c.percent_women, 3) AS us_men
FROM google_dei.bls.cpsaat18 c
WHERE c.year = 2021
  AND c.industry_group = 'Computer systems design and related services'

UNION ALL

SELECT 'BLS - Internet publishing and broadcasting and web search portals' AS source,
       c.percent_asian AS asian,
       c.percent_black_or_african_american AS black,
       c.percent_hispanic_or_latino AS hispanic_latinx,
       c.percent_white AS white,
       c.percent_women AS us_women,
       ROUND(1 - c.percent_women, 3) AS us_men
FROM google_dei.bls.cpsaat18 c
WHERE c.year = 2021
  AND c.subsector = 'Internet publishing and broadcasting and web search portals'

UNION ALL

SELECT 'Google Hiring (Overall)' AS source,
       h.race_asian AS asian,
       h.race_black AS black,
       h.race_hispanic_latinx AS hispanic_latinx,
       h.race_white AS white,
       h.gender_us_women AS us_women,
       h.gender_us_men AS us_men
FROM google_dei.google_dei.dar_non_intersectional_hiring h
WHERE h.report_year = 2021 AND h.workforce = 'overall'

UNION ALL

SELECT 'Google Representation (Overall)' AS source,
       r.race_asian AS asian,
       r.race_black AS black,
       r.race_hispanic_latinx AS hispanic_latinx,
       r.race_white AS white,
       r.gender_us_women AS us_women,
       r.gender_us_men AS us_men
FROM google_dei.google_dei.dar_non_intersectional_representation r
WHERE r.report_year = 2021 AND r.workforce = 'overall';
