SELECT COUNT(DISTINCT m.user_pseudo_id) AS distinct_pseudo_users
FROM ga4.ga4_obfuscated_sample_ecommerce.events_202101 m
UNNEST m.event_params AS ep
WHERE ep.`key` = 'engagement_time_msec'
  AND ep.`value`.int_value > 0
  AND m.event_date BETWEEN '20210101' AND '20210107'
  AND m.event_timestamp > 1609459199000000
  AND m.user_pseudo_id NOT IN (
    SELECT RAW n.user_pseudo_id
    FROM ga4.ga4_obfuscated_sample_ecommerce.events_202101 n
    UNNEST n.event_params AS ep2
    WHERE ep2.`key` = 'engagement_time_msec'
      AND ep2.`value`.int_value > 0
      AND n.event_date BETWEEN '20210105' AND '20210107'
      AND n.event_timestamp > 1609891199000000
  )