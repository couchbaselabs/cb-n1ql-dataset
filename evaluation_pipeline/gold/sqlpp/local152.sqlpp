WITH director_movies AS (
    SELECT
        d.name_id AS director_id,
        TRIM(n.name) AS director_name,
        m.id AS movie_id,
        m.duration,
        STR_TO_MILLIS(m.date_published) AS pub_ms,
        r.avg_rating,
        r.total_votes
    FROM `imdb_movies`.`imdb_movies_scope`.`director_mapping` d
    JOIN `imdb_movies`.`imdb_movies_scope`.`movies` m
        ON m.id = d.movie_id
    LEFT JOIN `imdb_movies`.`imdb_movies_scope`.`ratings` r
        ON r.movie_id = m.id
    LEFT JOIN `imdb_movies`.`imdb_movies_scope`.`names` n
        ON n.id = d.name_id
),

ordered_movies AS (
    SELECT
        dm.*,
        LAG(dm.pub_ms) OVER (
            PARTITION BY dm.director_id
            ORDER BY dm.pub_ms
        ) AS prev_pub_ms
    FROM director_movies dm
),

director_stats AS (
    SELECT
        director_id,
        director_name,
        COUNT(movie_id) AS movie_count,
        ROUND(
            AVG((pub_ms - prev_pub_ms) / 86400000),
            0
        ) AS avg_inter_movie_days,
        ROUND(AVG(avg_rating), 2) AS avg_rating,
        SUM(total_votes) AS total_votes,
        MIN(avg_rating) AS min_rating,
        MAX(avg_rating) AS max_rating,
        SUM(duration) AS total_movie_duration
    FROM ordered_movies
    GROUP BY director_id, director_name
)

SELECT
    director_id,
    director_name,
    movie_count,
    avg_inter_movie_days,
    avg_rating,
    total_votes,
    min_rating,
    max_rating,
    total_movie_duration
FROM director_stats
ORDER BY movie_count DESC, total_movie_duration DESC
LIMIT 9;