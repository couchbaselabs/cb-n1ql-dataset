WITH step_scores AS (
    SELECT
        ms.name,
        ms.version,
        ms.step,
        MAX(CASE WHEN ms.model != 'Stack' THEN ms.test_score ELSE NULL END) AS max_non_stack_test_score,
        MAX(CASE WHEN ms.model = 'Stack' THEN ms.test_score ELSE NULL END) AS stack_test_score
    FROM `stacking`.`stacking_scope`.`model_score` AS ms
    GROUP BY ms.name, ms.version, ms.step
),
model_status AS (
    SELECT
        ss.name,
        ss.version,
        CASE
            WHEN MAX(CASE WHEN ss.stack_test_score IS NOT NULL AND ss.max_non_stack_test_score < ss.stack_test_score THEN 1 ELSE 0 END) = 1 THEN 'strong'
            WHEN MAX(CASE WHEN ss.stack_test_score IS NOT NULL AND ss.max_non_stack_test_score = ss.stack_test_score THEN 1 ELSE 0 END) = 1 THEN 'soft'
            ELSE NULL
        END AS status
    FROM step_scores AS ss
    GROUP BY ss.name, ss.version
),
l1_status_counts AS (
    SELECT
        ms.status,
        m.L1_model,
        COUNT(DISTINCT ms.name || '|' || TOSTRING(ms.version)) AS occurrences
    FROM model_status AS ms
    JOIN `stacking`.`stacking_scope`.`model` AS m
        ON ms.name = m.name
       AND ms.version = m.version
    WHERE ms.status IS NOT NULL
    GROUP BY ms.status, m.L1_model
),
ranked_counts AS (
    SELECT
        lsc.status,
        lsc.L1_model,
        lsc.occurrences,
        RANK() OVER (PARTITION BY lsc.status ORDER BY lsc.occurrences DESC, lsc.L1_model) AS rnk
    FROM l1_status_counts AS lsc
)
SELECT
    rc.status AS STATUS,
    rc.L1_model AS L1_MODEL,
    rc.occurrences AS OCCURRENCES
FROM ranked_counts AS rc
WHERE rc.rnk = 1
ORDER BY rc.status, rc.L1_model;