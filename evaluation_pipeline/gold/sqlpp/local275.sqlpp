WITH numbered_sales AS (
    SELECT
        ms.product_id,
        ms.mth,
        ms.qty,
        ROW_NUMBER() OVER (PARTITION BY ms.product_id ORDER BY ms.mth) AS time_step
    FROM `oracle_sql`.`oracle_sql_scope`.`monthly_sales` ms
    WHERE ms.mth >= '2016-01'
),
windowed_sales AS (
    SELECT
        ns.product_id,
        ns.time_step,
        ns.qty,
        ns.mth,
        AVG(ns.qty) OVER (
            PARTITION BY ns.product_id
            ORDER BY ns.time_step
            ROWS BETWEEN 5 PRECEDING AND 6 FOLLOWING
        ) AS avg_first,
        AVG(ns.qty) OVER (
            PARTITION BY ns.product_id
            ORDER BY ns.time_step
            ROWS BETWEEN 6 PRECEDING AND 5 FOLLOWING
        ) AS avg_second
    FROM numbered_sales ns
),
cma_calc AS (
    SELECT
        product_id,
        time_step,
        qty,
        mth,
        (avg_first + avg_second) / 2.0 AS cma
    FROM windowed_sales
    WHERE time_step BETWEEN 7 AND 30
),
seasonal_ratios AS (
    SELECT
        cc.product_id,
        ((cc.time_step - 1) % 12) + 1 AS month_of_year,
        AVG(cc.qty / NULLIF(cc.cma, 0)) AS avg_seasonal_ratio
    FROM cma_calc cc
    WHERE cc.cma IS NOT NULL AND cc.cma > 0
    GROUP BY cc.product_id, ((cc.time_step - 1) % 12) + 1
),
months_2017 AS (
    SELECT
        sr.product_id,
        sr.month_of_year,
        sr.avg_seasonal_ratio
    FROM seasonal_ratios sr
    WHERE sr.month_of_year BETWEEN 1 AND 12
),
products_consistent AS (
    SELECT product_id
    FROM months_2017
    GROUP BY product_id
    HAVING COUNT(*) = 12
       AND MIN(avg_seasonal_ratio) > 2
)
SELECT
    p.name AS output
FROM products_consistent pc
JOIN `oracle_sql`.`oracle_sql_scope`.`products` p ON pc.product_id = p.id
ORDER BY p.name;
