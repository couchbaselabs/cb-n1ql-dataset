SELECT
    c.customer_unique_id,
    COUNT(DISTINCT o.order_id) AS delivered_orders,
    AVG(op.payment_value) AS avg_payment_value,
    c.customer_city,
    c.customer_state
FROM `Brazilian_E_Commerce`.`Brazilian_E_Commerce_scope`.`olist_orders` AS o
JOIN `Brazilian_E_Commerce`.`Brazilian_E_Commerce_scope`.`olist_customers` AS c
    ON o.customer_id = c.customer_id
JOIN `Brazilian_E_Commerce`.`Brazilian_E_Commerce_scope`.`olist_order_payments` AS op
    ON o.order_id = op.order_id
WHERE o.order_status = 'delivered'
GROUP BY c.customer_unique_id, c.customer_city, c.customer_state
ORDER BY delivered_orders DESC, c.customer_unique_id
LIMIT 3;
 