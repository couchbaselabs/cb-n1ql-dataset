WITH daily_txn AS (
    SELECT ct.customer_id, ct.txn_date,
           SUM(CASE WHEN ct.txn_type = "deposit" THEN ct.txn_amount
                    ELSE -ct.txn_amount END) AS daily_net
    FROM bank_sales_trading.bank_sales_trading_scope.customer_transactions ct
    GROUP BY ct.customer_id, ct.txn_date
),

date_ranges AS (
    SELECT ct.customer_id,
           MIN(ct.txn_date) AS min_date,
           MAX(ct.txn_date) AS max_date,
           DATE_DIFF_STR(MAX(ct.txn_date), MIN(ct.txn_date), "day") AS num_days
    FROM bank_sales_trading.bank_sales_trading_scope.customer_transactions ct
    GROUP BY ct.customer_id
),

customer_dates AS (
    SELECT dr.customer_id,
           DATE_ADD_STR(dr.min_date, i, "day") AS dt
    FROM date_ranges dr
    UNNEST ARRAY_RANGE(0, dr.num_days + 1) AS i
),

daily_with_txn AS (
    SELECT cd.customer_id, cd.dt,
           COALESCE(dt2.daily_net, 0) AS daily_net
    FROM customer_dates cd
    LEFT JOIN daily_txn dt2
      ON cd.customer_id = dt2.customer_id
     AND cd.dt = dt2.txn_date
),

running_balance AS (
    SELECT dw.customer_id, dw.dt,
           SUM(dw.daily_net) OVER (
               PARTITION BY dw.customer_id
               ORDER BY dw.dt
           ) AS balance,
           ROW_NUMBER() OVER (
               PARTITION BY dw.customer_id
               ORDER BY dw.dt
           ) AS day_num
    FROM daily_with_txn dw
),

rolling_avg AS (
    SELECT rb.customer_id, rb.dt,
           AVG(rb.balance) OVER (
               PARTITION BY rb.customer_id
               ORDER BY rb.dt
               ROWS BETWEEN 29 PRECEDING AND CURRENT ROW
           ) AS avg_30d,
           rb.day_num
    FROM running_balance rb
),

filtered AS (
    SELECT ra.customer_id, ra.dt,
           CASE WHEN ra.avg_30d < 0 THEN 0 ELSE ra.avg_30d END AS avg_30d_adj,
           DATE_TRUNC_STR(ra.dt,"month") AS month_key
    FROM rolling_avg ra
    WHERE ra.day_num >= 30
),

first_month AS (
    SELECT ct.customer_id,
           DATE_TRUNC_STR(MIN(ct.txn_date),"month") AS first_month_key
    FROM bank_sales_trading.bank_sales_trading_scope.customer_transactions ct
    GROUP BY ct.customer_id
),

excluded AS (
    SELECT f.customer_id, f.dt, f.avg_30d_adj, f.month_key
    FROM filtered f
    JOIN first_month fm
      ON f.customer_id = fm.customer_id
    WHERE f.month_key > fm.first_month_key
),

max_per_cust_month AS (
    SELECT e.customer_id, e.month_key,
           MAX(e.avg_30d_adj) AS max_avg
    FROM excluded e
    GROUP BY e.customer_id, e.month_key
)

SELECT
    mpcm.month_key AS month,
    ROUND(SUM(mpcm.max_avg),3) AS monthly_total_max_30d_avg
FROM max_per_cust_month mpcm
GROUP BY mpcm.month_key
ORDER BY mpcm.month_key;