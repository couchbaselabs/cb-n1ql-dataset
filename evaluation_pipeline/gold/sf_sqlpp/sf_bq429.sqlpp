WITH median_income_diff_by_zipcode AS (
    SELECT
        z18.geo_id AS zip_code,
        AVG(z18.median_income - z15.median_income) AS median_income_diff
    FROM `censusbureauacs2`.`census_bureau_acs`.`zip_codes_2018_5yr` z18
    JOIN `censusbureauacs2`.`census_bureau_acs`.`zip_codes_2015_5yr` z15 
        ON z18.geo_id = z15.geo_id
    WHERE z18.median_income IS NOT NULL 
      AND z15.median_income IS NOT NULL
    GROUP BY z18.geo_id
)
SELECT 
    geo.state_name AS state,
    AVG(i.median_income_diff) AS avg_median_income_diff_2018_minus_2015,
    AVG(
        IFMISSINGORNULL(census.employed_wholesale_trade, 0) * 0.38423645320197042 +
        (IFMISSINGORNULL(census.employed_agriculture_forestry_fishing_hunting_mining, 0) + IFMISSINGORNULL(census.employed_construction, 0)) * 0.48071410777129553 +
        IFMISSINGORNULL(census.employed_arts_entertainment_recreation_accommodation_food, 0) * 0.89455676291236841 +
        IFMISSINGORNULL(census.employed_information, 0) * 0.31315240083507306 +
        IFMISSINGORNULL(census.employed_retail_trade, 0) * 0.51
    ) AS avg_vulnerable_employees_2017
FROM `censusbureauacs2`.`census_bureau_acs`.`zip_codes_2017_5yr` AS census
JOIN median_income_diff_by_zipcode i 
    ON census.geo_id = i.zip_code
JOIN `censusbureauacs2`.`geo_us_boundaries`.`zip_codes` geo 
    ON census.geo_id = geo.zip_code
GROUP BY geo.state_name
ORDER BY avg_median_income_diff_2018_minus_2015 DESC
LIMIT 5;