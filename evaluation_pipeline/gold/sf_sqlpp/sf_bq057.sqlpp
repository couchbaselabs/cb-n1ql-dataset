WITH totals AS (
         SELECT
             block_timestamp_month AS tx_month,
             COUNT(`hash`) AS tx_count,
             SUM(input_count) AS tx_inputs,
             SUM(output_count) AS tx_outputs,
             SUM(input_value) / 100000000 AS tx_input_val,
             SUM(output_value) / 100000000 AS
     tx_output_val
         FROM crypto.crypto_bitcoin.transactions
         WHERE block_timestamp_month BETWEEN '2021-01-01'
     AND '2021-12-31'
         GROUP BY block_timestamp_month
     ),
     coinjoinOuts AS (
         SELECT
             txs.`hash`,
             txs.block_number,
             txs.block_timestamp_month,
             txs.input_count,
             txs.output_count,
             txs.input_value,
             txs.output_value,
             o.`value` AS outputs_val
         FROM crypto.crypto_bitcoin.transactions AS txs
         UNNEST txs.outputs AS o
         WHERE txs.output_count > 2
           AND txs.output_value <= txs.input_value
           AND txs.block_timestamp_month BETWEEN
     '2021-01-01' AND '2021-12-31'
     ),
     coinjoinTxs AS (
         SELECT
             coinjoinouts.`hash` AS cjhash,
             coinjoinouts.outputs_val AS outputVal,
             COUNT(*) AS cjOuts
         FROM coinjoinOuts AS coinjoinouts
         GROUP BY coinjoinouts.`hash`,
     coinjoinouts.outputs_val
         HAVING COUNT(*) > 1
     ),
     coinjoinsD AS (
         SELECT DISTINCT
             coinjoinouts.`hash`,
             coinjoinouts.block_number,
             coinjoinouts.block_timestamp_month,
             coinjoinouts.input_count,
             coinjoinouts.output_count,
             coinjoinouts.input_value,
             coinjoinouts.output_value
         FROM coinjoinOuts AS coinjoinouts
         INNER JOIN coinjoinTxs AS coinjointxs
             ON coinjoinouts.`hash` = coinjointxs.cjhash
     ),
     coinjoins AS (
         SELECT
             cjs.block_timestamp_month AS cjs_month,
             COUNT(cjs.`hash`) AS cjs_count,
             SUM(cjs.input_count) AS cjs_inputs,
             SUM(cjs.output_count) AS cjs_outputs,
             SUM(cjs.input_value) / 100000000 AS
     cjs_input_val,
             SUM(cjs.output_value) / 100000000 AS
     cjs_output_val
         FROM coinjoinsD AS cjs
         GROUP BY cjs.block_timestamp_month
     )
     SELECT DATE_PART_STR(totals.tx_month, 'month') AS month,
            ROUND(coinjoins.cjs_count / totals.tx_count *
     100, 1) AS tx_percent,
            ROUND((coinjoins.cjs_inputs / totals.tx_inputs
      + coinjoins.cjs_outputs / totals.tx_outputs) / 2 *
     100, 1) AS utxos_percent,
            ROUND(coinjoins.cjs_input_val /
     totals.tx_input_val * 100, 1) AS value_percent
     FROM totals
     INNER JOIN coinjoins
         ON totals.tx_month = coinjoins.cjs_month
     ORDER BY value_percent DESC
     LIMIT 1;