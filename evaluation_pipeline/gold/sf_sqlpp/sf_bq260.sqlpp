WITH filtered_users AS (
    SELECT u.gender, u.age
    FROM `thelookecommerce`.`thelook_ecommerce`.`users` AS u
    WHERE u.created_at >= 1546300800000000
      AND u.created_at < 1651363200000000
      AND u.gender IS NOT NULL
      AND u.gender IS NOT MISSING
      AND u.age IS NOT NULL
      AND u.age IS NOT MISSING
),
age_bounds AS (
    SELECT
        fu.gender,
        MIN(fu.age) AS youngest_age,
        MAX(fu.age) AS oldest_age
    FROM filtered_users AS fu
    GROUP BY fu.gender
)
SELECT
    ab.gender,
    ab.youngest_age,
    SUM(CASE WHEN fu.age = ab.youngest_age THEN 1 ELSE 0 END) AS youngest_user_count,
    ab.oldest_age,
    SUM(CASE WHEN fu.age = ab.oldest_age THEN 1 ELSE 0 END) AS oldest_user_count
FROM age_bounds AS ab
JOIN filtered_users AS fu
    ON fu.gender = ab.gender
GROUP BY ab.gender, ab.youngest_age, ab.oldest_age
ORDER BY ab.gender;