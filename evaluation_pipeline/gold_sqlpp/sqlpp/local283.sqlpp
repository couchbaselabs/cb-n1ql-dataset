WITH all_points AS (
    SELECT m.season, m.league_id, m.country_id, m.home_team_api_id AS team_api_id,
           CASE WHEN m.home_team_goal > m.away_team_goal THEN 3
                WHEN m.home_team_goal = m.away_team_goal THEN 1
                ELSE 0 END AS pts
    FROM EU_soccer.EU_soccer_scope.Match AS m
    UNION ALL
    SELECT m.season, m.league_id, m.country_id, m.away_team_api_id AS team_api_id,
           CASE WHEN m.away_team_goal > m.home_team_goal THEN 3
                WHEN m.away_team_goal = m.home_team_goal THEN 1
                ELSE 0 END AS pts
    FROM EU_soccer.EU_soccer_scope.Match AS m
),
team_season_points AS (
    SELECT ap.season, ap.league_id, ap.country_id, ap.team_api_id,
           SUM(ap.pts) AS total_points
    FROM all_points AS ap
    GROUP BY ap.season, ap.league_id, ap.country_id, ap.team_api_id
),
ranked AS (
    SELECT tsp.season, tsp.league_id, tsp.country_id, tsp.team_api_id, tsp.total_points,
           t.team_long_name,
           ROW_NUMBER() OVER (
               PARTITION BY tsp.season, tsp.league_id, tsp.country_id
               ORDER BY tsp.total_points DESC, t.team_long_name ASC
           ) AS rnk
    FROM team_season_points AS tsp
    JOIN EU_soccer.EU_soccer_scope.Team AS t ON tsp.team_api_id = t.team_api_id
)
SELECT r.season,
       r.team_long_name AS champion_team,
       l.name AS league,
       c.name AS country,
       r.total_points
FROM ranked AS r
JOIN EU_soccer.EU_soccer_scope.League AS l ON r.league_id = l.id
JOIN EU_soccer.EU_soccer_scope.Country AS c ON r.country_id = c.id
WHERE r.rnk = 1
ORDER BY r.season, l.name, c.name;
