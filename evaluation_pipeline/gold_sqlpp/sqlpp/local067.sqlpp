WITH italy_customers AS (
    SELECT cu.cust_id
    FROM complex_oracle.complex_oracle_scope.customers AS cu
    WHERE cu.country_id = (
        SELECT RAW co.country_id
        FROM complex_oracle.complex_oracle_scope.countries AS co
        WHERE co.country_name = "Italy"
    )[0]
),

dec_2021_times AS (
    SELECT t.time_id
    FROM complex_oracle.complex_oracle_scope.times AS t
    WHERE t.calendar_year = 2021 AND t.calendar_month_number = 12
),

customer_profits AS (
    SELECT
        s.cust_id,
        SUM(s.amount_sold - s.quantity_sold * co.unit_cost) AS total_profit
    FROM complex_oracle.complex_oracle_scope.sales AS s
    JOIN complex_oracle.complex_oracle_scope.costs AS co
        ON s.prod_id = co.prod_id
        AND s.time_id = co.time_id
        AND s.channel_id = co.channel_id
        AND s.promo_id = co.promo_id
    WHERE s.cust_id IN (SELECT RAW ic.cust_id FROM italy_customers ic)
      AND s.time_id IN (SELECT RAW dt.time_id FROM dec_2021_times dt)
    GROUP BY s.cust_id
),

tiered AS (
    SELECT
        cp.total_profit,
        NTILE(10) OVER (ORDER BY cp.total_profit ASC) AS tier
    FROM customer_profits cp
)

SELECT
    t.tier AS TIER,
    MIN(t.total_profit) AS LOWEST_PROFIT,
    MAX(t.total_profit) AS HIGHEST_PROFIT
FROM tiered t
GROUP BY t.tier
ORDER BY t.tier;
