SELECT district
FROM (
  SELECT S.starting_district AS district
  FROM austin.austin_bikeshare.bikeshare_trips AS T
  INNER JOIN (
    SELECT station_id, council_district AS starting_district
    FROM austin.austin_bikeshare.bikeshare_stations
    WHERE status = 'active'
  ) AS S ON T.start_station_id = S.station_id
  WHERE S.starting_district IN (
    SELECT RAW s2.council_district
    FROM austin.austin_bikeshare.bikeshare_stations s2
    WHERE s2.status = 'active'
      AND s2.station_id = TONUMBER(T.end_station_id)
  )
  AND T.start_station_id != TONUMBER(T.end_station_id)
) sub
GROUP BY district
ORDER BY COUNT(*) DESC
LIMIT 1;
