WITH bea_2012 AS (
    SELECT
        f.GeoFIPS,
        f.GeoName,
        f.Earnings_per_job_avg AS earnings_2012
    FROM sdoh.sdoh_bea_cainc30.fips AS f
    WHERE f.Year = "2012-01-01"
      AND f.GeoName LIKE "%MA"
),

bea_2017 AS (
    SELECT
        f.GeoFIPS,
        f.GeoName,
        f.Earnings_per_job_avg AS earnings_2017
    FROM sdoh.sdoh_bea_cainc30.fips AS f
    WHERE f.Year = "2017-01-01"
      AND f.GeoName LIKE "%MA"
),

earnings_diff AS (
    SELECT
        b17.GeoFIPS,
        b17.GeoName,
        b17.earnings_2017,
        b12.earnings_2012,
        (b17.earnings_2017 - b12.earnings_2012) AS earnings_change
    FROM bea_2017 AS b17
    JOIN bea_2012 AS b12
    ON b17.GeoFIPS = b12.GeoFIPS
)

SELECT *
FROM earnings_diff
WHERE earnings_change IS NOT NULL
ORDER BY earnings_change DESC;