WITH acs_2017 AS (
    SELECT 
        a.geo_id,
        a.income_less_10000 AS i10,
        a.income_10000_14999 AS i15,
        a.income_15000_19999 AS i20
    FROM `sdoh`.`census_bureau_acs`.`county_2017_5yr` AS a
),

snap_2017_Jan AS (
    SELECT 
        s.FIPS,
        s.SNAP_All_Participation_Households AS snap_total
    FROM `sdoh`.`sdoh_snap_enrollment`.`snap_enrollment` AS s
    WHERE s.Date = "2017-01-01"
)

SELECT 
    a.geo_id,
    s.snap_total,
    (a.i10 + a.i15 + a.i20) AS households_under_20,
    (a.i10 + a.i15 + a.i20) / s.snap_total AS under_20_snap_ratio
FROM acs_2017 AS a
JOIN snap_2017_Jan AS s
ON a.geo_id = s.FIPS
WHERE s.snap_total > 0
ORDER BY s.snap_total DESC
LIMIT 10;