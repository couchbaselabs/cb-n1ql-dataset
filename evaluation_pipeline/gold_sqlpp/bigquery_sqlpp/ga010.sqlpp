SELECT channel AS CHANNEL, sessions AS SESSIONS FROM (
  SELECT channel, sessions,
    DENSE_RANK() OVER (ORDER BY sessions DESC) AS rnk
  FROM (
    SELECT channel, COUNT(DISTINCT CONCAT(e.user_pseudo_id, "-", TOSTRING(
      (FIRST ep.`value`.int_value FOR ep IN e.event_params WHEN ep.`key` = "ga_session_id" END)
    ))) AS sessions
    FROM ga4.ga4_obfuscated_sample_ecommerce.events_202012 e
    LET source = e.traffic_source.source,
        medium = e.traffic_source.medium,
        campaign = e.traffic_source.`name`,
        channel = CASE
          WHEN source = "(direct)" AND medium IN ["(not set)","(none)"] THEN "Direct"
          WHEN REGEXP_CONTAINS(IFNULL(campaign,""), "cross-network") THEN "Cross-network"
          WHEN (REGEXP_CONTAINS(IFNULL(source,""),"alibaba|amazon|google shopping|shopify|etsy|ebay|stripe|walmart")
               OR REGEXP_CONTAINS(IFNULL(campaign,""), "(([^a-df-z]|^)shop|shopping)"))
              AND REGEXP_CONTAINS(IFNULL(medium,""), "(cp|ppc|paid)") THEN "Paid Shopping"
          WHEN REGEXP_CONTAINS(IFNULL(source,""),"baidu|bing|duckduckgo|ecosia|google|yahoo|yandex")
              AND REGEXP_CONTAINS(IFNULL(medium,""),"^(.*cp.*|ppc|paid.*)$") THEN "Paid Search"
          WHEN REGEXP_CONTAINS(IFNULL(source,""),"badoo|facebook|fb|instagram|linkedin|pinterest|tiktok|twitter|whatsapp")
              AND REGEXP_CONTAINS(IFNULL(medium,""),"^(.*cp.*|ppc|paid.*)$") THEN "Paid Social"
          WHEN REGEXP_CONTAINS(IFNULL(source,""),"dailymotion|disneyplus|netflix|youtube|vimeo|twitch")
              AND REGEXP_CONTAINS(IFNULL(medium,""),"^(.*cp.*|ppc|paid.*)$") THEN "Paid Video"
          WHEN medium IN ["display", "banner", "expandable", "interstitial", "cpm"] THEN "Display"
          WHEN REGEXP_CONTAINS(IFNULL(source,""),"alibaba|amazon|google shopping|shopify|etsy|ebay|stripe|walmart")
              OR REGEXP_CONTAINS(IFNULL(campaign,""), "(([^a-df-z]|^)shop|shopping)") THEN "Organic Shopping"
          WHEN REGEXP_CONTAINS(IFNULL(source,""),"badoo|facebook|fb|instagram|linkedin|pinterest|tiktok|twitter|whatsapp")
              OR medium IN ["social","social-network","social-media","sm","social network","social media"] THEN "Organic Social"
          WHEN REGEXP_CONTAINS(IFNULL(source,""),"dailymotion|disneyplus|netflix|youtube|vimeo|twitch")
              OR REGEXP_CONTAINS(IFNULL(medium,""),"^(.*video.*)$") THEN "Organic Video"
          WHEN medium = "affiliate" THEN "Affiliates"
          WHEN medium = "referral" THEN "Referral"
          WHEN REGEXP_CONTAINS(IFNULL(source,""),"email|e-mail|e_mail|e mail")
              OR REGEXP_CONTAINS(IFNULL(medium,""),"email|e-mail|e_mail|e mail") THEN "Email"
          WHEN REGEXP_CONTAINS(IFNULL(source,""),"baidu|bing|duckduckgo|ecosia|google|yahoo|yandex")
              OR medium = "organic" THEN "Organic Search"
          WHEN medium = "audio" THEN "Audio"
          WHEN medium = "sms" THEN "SMS"
          WHEN IFNULL(medium,"") LIKE "%push"
              OR REGEXP_CONTAINS(IFNULL(medium,""),"mobile|notification") THEN "Mobile Push Notifications"
          ELSE "Unassigned"
        END
    GROUP BY channel
  ) t
) ranked
WHERE ranked.rnk = 4