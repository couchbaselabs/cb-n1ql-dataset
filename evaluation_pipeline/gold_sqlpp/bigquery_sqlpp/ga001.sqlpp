WITH Params AS (
    SELECT "Google Navy Speckled Tee" AS selected_product
),

PurchaseEvents AS (
    SELECT
        T.user_pseudo_id,
        T.items
    FROM ga4.ga4_obfuscated_sample_ecommerce.events_202012 AS T
    WHERE T.event_date BETWEEN "20201201" AND "20201231"
      AND T.event_name = "purchase"
),

ProductABuyers AS (
    SELECT DISTINCT P.user_pseudo_id
    FROM PurchaseEvents AS P
    UNNEST P.items AS item
    WHERE item.item_name = (SELECT RAW selected_product FROM Params)[0]
)

SELECT
    item.item_name AS item_name,
    SUM(IFMISSINGORNULL(item.quantity, 0)) AS item_quantity
FROM PurchaseEvents AS P

JOIN ProductABuyers AS B
ON P.user_pseudo_id = B.user_pseudo_id

UNNEST P.items AS item

WHERE item.item_name != (SELECT RAW selected_product FROM Params)[0]

GROUP BY item.item_name
ORDER BY item_quantity DESC
LIMIT 1;