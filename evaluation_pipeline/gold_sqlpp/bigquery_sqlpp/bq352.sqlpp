WITH natality_2018 AS (
    SELECT 
        n.County_of_Residence_FIPS AS FIPS,
        n.Ave_Number_of_Prenatal_Wks AS Vist_Ave,
        n.County_of_Residence
    FROM `sdoh`.`sdoh_cdc_wonder_natality`.`county_natality` AS n
    WHERE SUBSTR(n.County_of_Residence_FIPS, 0, 2) = "55"
      AND n.Year = "2018-01-01"
),

acs_2017 AS (
    SELECT 
        a.geo_id,
        a.commute_45_59_mins,
        a.employed_pop
    FROM `sdoh`.`census_bureau_acs`.`county_2017_5yr` AS a
),

corr_tbl AS (
    SELECT
        n.County_of_Residence,
        ROUND((a.commute_45_59_mins / a.employed_pop) * 100, 2) AS percent_high_travel,
        n.Vist_Ave
    FROM acs_2017 AS a
    JOIN natality_2018 AS n
    ON a.geo_id = n.FIPS
)

SELECT 
    c.County_of_Residence, 
    c.Vist_Ave
FROM corr_tbl AS c
WHERE c.percent_high_travel > 5;