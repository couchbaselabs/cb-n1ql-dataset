SELECT
    distinct(page_location),
    page_title,
  
    CASE
        -- PDP
        WHEN ARRAY_LENGTH(parts) >= 5
             AND CONTAINS(parts[len - 1], "+")
             AND (
                LOWER(parts[len-2]) IN [
                    "accessories","apparel","brands","campus+collection","drinkware",
                "electronics","google+redesign","lifestyle","nest",
                "new+2015+logo","notebooks+journals","office",
                "shop+by+brand","small+goods","stationery","wearables"
                ]
                OR
                LOWER(parts[len-3]) IN [
                    "accessories","apparel","brands","campus+collection","drinkware",
                "electronics","google+redesign","lifestyle","nest",
                "new+2015+logo","notebooks+journals","office",
                "shop+by+brand","small+goods","stationery","wearables"
                ]
             )
        THEN "PDP"

        -- PLP
        WHEN ARRAY_LENGTH(parts) >= 4
             AND NOT CONTAINS(parts[len - 1], "+")
             AND (
                LOWER(parts[len-1]) IN [
                    "accessories","apparel","brands","drinkware",
                    "electronics","google+redesign","lifestyle",
                    "office","shop+by+brand","stationery"
                ]
                OR
                LOWER(parts[len-2]) IN [
                    "accessories","apparel","brands","drinkware",
                    "electronics","google+redesign","lifestyle",
                    "office","shop+by+brand","stationery"
                ]
             )
        THEN "PLP"

        ELSE "Other"
    END AS page_category

FROM (

    SELECT
        T.event_timestamp,

        MAX(CASE WHEN ep.`key` = "page_location"
                 THEN ep.`value`.string_value END) AS page_location,

        MAX(CASE WHEN ep.`key` = "page_title"
                 THEN ep.`value`.string_value END) AS page_title,

        SPLIT(
            MAX(CASE WHEN ep.`key` = "page_location"
                     THEN ep.`value`.string_value END),
            "/"
        ) AS parts,

        ARRAY_LENGTH(
            SPLIT(
                MAX(CASE WHEN ep.`key` = "page_location"
                         THEN ep.`value`.string_value END),
                "/"
            )
        ) AS len

    FROM ga4.ga4_obfuscated_sample_ecommerce.events_202101 AS T
    UNNEST T.event_params AS ep

    WHERE T.event_name = "page_view"
      AND T.event_date = "20210102"
      AND T.user_pseudo_id = "1402138.5184246691"

    GROUP BY T.event_timestamp

) AS extracted

ORDER BY event_timestamp;