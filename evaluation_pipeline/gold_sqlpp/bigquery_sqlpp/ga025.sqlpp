WITH all_events AS (
    SELECT user_pseudo_id, event_name, event_date, event_timestamp, user_first_touch_timestamp
    FROM firebase.analytics_153293282.events_201809
    UNION ALL
    SELECT user_pseudo_id, event_name, event_date, event_timestamp, user_first_touch_timestamp
    FROM firebase.analytics_153293282.events_201810
),
first_open_users AS (
    SELECT user_pseudo_id,
           MIN(SUBSTR(event_date,0,4)||'-'||SUBSTR(event_date,4,2)||'-'||SUBSTR(event_date,6,2)) AS first_open_date
    FROM all_events
    WHERE event_name = 'first_open'
      AND event_date >= "20180901" AND event_date <= "20180930"
    GROUP BY user_pseudo_id
),
uninstall_events AS (
    SELECT user_pseudo_id,
           MIN(SUBSTR(event_date,0,4)||'-'||SUBSTR(event_date,4,2)||'-'||SUBSTR(event_date,6,2)) AS uninstall_date
    FROM all_events
    WHERE event_name = 'app_remove'
    GROUP BY user_pseudo_id
),
quick_uninstalls AS (
    SELECT f.user_pseudo_id
    FROM first_open_users f
    JOIN uninstall_events u ON f.user_pseudo_id = u.user_pseudo_id
    WHERE DATE_DIFF_STR(u.uninstall_date, f.first_open_date, "day") <= 7
      AND DATE_DIFF_STR(u.uninstall_date, f.first_open_date, "day") >= 0
),
crash_users AS (
    SELECT DISTINCT user_pseudo_id
    FROM all_events
    WHERE event_name = 'app_exception'
)
SELECT
    COUNT(DISTINCT CASE WHEN c.user_pseudo_id IS NOT NULL THEN q.user_pseudo_id END) * 100.0 /
    COUNT(DISTINCT q.user_pseudo_id) AS PERCENTAGE
FROM quick_uninstalls q
LEFT JOIN crash_users c ON q.user_pseudo_id = c.user_pseudo_id
