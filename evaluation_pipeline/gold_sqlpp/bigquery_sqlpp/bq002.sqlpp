WITH daily_revenue AS (
    SELECT s.trafficSource.source AS source, s.`date`,
           SUM(p.productRevenue) / 1000000 AS revenue
    FROM ga360.google_analytics_sample.ga_sessions_201701 s
    UNNEST s.hits AS h UNNEST h.product AS p
    WHERE p.productRevenue IS NOT NULL
    GROUP BY s.trafficSource.source, s.`date`
    UNION ALL
    SELECT s.trafficSource.source AS source, s.`date`,
           SUM(p.productRevenue) / 1000000 AS revenue
    FROM ga360.google_analytics_sample.ga_sessions_201702 s
    UNNEST s.hits AS h UNNEST h.product AS p
    WHERE p.productRevenue IS NOT NULL
    GROUP BY s.trafficSource.source, s.`date`
    UNION ALL
    SELECT s.trafficSource.source AS source, s.`date`,
           SUM(p.productRevenue) / 1000000 AS revenue
    FROM ga360.google_analytics_sample.ga_sessions_201703 s
    UNNEST s.hits AS h UNNEST h.product AS p
    WHERE p.productRevenue IS NOT NULL
    GROUP BY s.trafficSource.source, s.`date`
    UNION ALL
    SELECT s.trafficSource.source AS source, s.`date`,
           SUM(p.productRevenue) / 1000000 AS revenue
    FROM ga360.google_analytics_sample.ga_sessions_201704 s
    UNNEST s.hits AS h UNNEST h.product AS p
    WHERE p.productRevenue IS NOT NULL
    GROUP BY s.trafficSource.source, s.`date`
    UNION ALL
    SELECT s.trafficSource.source AS source, s.`date`,
           SUM(p.productRevenue) / 1000000 AS revenue
    FROM ga360.google_analytics_sample.ga_sessions_201705 s
    UNNEST s.hits AS h UNNEST h.product AS p
    WHERE p.productRevenue IS NOT NULL
    GROUP BY s.trafficSource.source, s.`date`
    UNION ALL
    SELECT s.trafficSource.source AS source, s.`date`,
           SUM(p.productRevenue) / 1000000 AS revenue
    FROM ga360.google_analytics_sample.ga_sessions_201706 s
    UNNEST s.hits AS h UNNEST h.product AS p
    WHERE p.productRevenue IS NOT NULL
    GROUP BY s.trafficSource.source, s.`date`
),

top_source AS (
    SELECT RAW dr.source
    FROM daily_revenue dr
    GROUP BY dr.source
    ORDER BY SUM(dr.revenue) DESC
    LIMIT 1
),

filtered AS (
    SELECT dr.`date`, dr.revenue
    FROM daily_revenue dr
    WHERE dr.source IN top_source
),

max_daily AS (
    SELECT f.revenue AS max_revenue
    FROM filtered f
    ORDER BY f.revenue DESC
    LIMIT 1
),

max_weekly AS (
    SELECT SUM(f.revenue) AS max_revenue
    FROM filtered f
    GROUP BY TOSTRING(DATE_PART_STR(
        SUBSTR(f.`date`, 0, 4) || "-" || SUBSTR(f.`date`, 4, 2) || "-" || SUBSTR(f.`date`, 6, 2), "year"
    )) || "W" || TOSTRING(DATE_PART_STR(
        SUBSTR(f.`date`, 0, 4) || "-" || SUBSTR(f.`date`, 4, 2) || "-" || SUBSTR(f.`date`, 6, 2), "week"
    ))
    ORDER BY max_revenue DESC
    LIMIT 1
),

max_monthly AS (
    SELECT SUM(f.revenue) AS max_revenue
    FROM filtered f
    GROUP BY TOSTRING(DATE_PART_STR(
        SUBSTR(f.`date`, 0, 4) || "-" || SUBSTR(f.`date`, 4, 2) || "-" || SUBSTR(f.`date`, 6, 2), "year"
    )) || "0" || TOSTRING(DATE_PART_STR(
        SUBSTR(f.`date`, 0, 4) || "-" || SUBSTR(f.`date`, 4, 2) || "-" || SUBSTR(f.`date`, 6, 2), "month"
    ))
    ORDER BY max_revenue DESC
    LIMIT 1
)

SELECT md.max_revenue FROM max_daily md
UNION ALL
SELECT mw.max_revenue FROM max_weekly mw
UNION ALL
SELECT mm.max_revenue FROM max_monthly mm
ORDER BY max_revenue DESC;
