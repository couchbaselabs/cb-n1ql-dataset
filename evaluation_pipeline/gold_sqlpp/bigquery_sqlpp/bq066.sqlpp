WITH natality_agg AS (
  SELECT
    SUBSTR(n.Year, 0, 4) AS year,
    n.County_of_Residence_FIPS AS county,
    SUM(n.Births) AS total_births,
    SUM(CASE 
          WHEN n.Maternal_Morbidity_Desc = "None checked" 
          THEN n.Births 
          ELSE 0 
        END) AS births_without_morbidity
  FROM `sdoh`.`sdoh_cdc_wonder_natality`.`county_natality_by_maternal_morbidity` n
  WHERE n.Year >= "2016-01-01"
    AND n.Year <  "2019-01-01"
  GROUP BY SUBSTR(n.Year, 0, 4), n.County_of_Residence_FIPS
),

census AS (
  SELECT "2016" AS year, p.geo_id AS county,
         (p.poverty * 100.0 / p.pop_determined_poverty_status) AS poverty_rate
  FROM `sdoh`.`census_bureau_acs`.`county_2015_5yr` p
  WHERE p.pop_determined_poverty_status > 0

  UNION ALL

  SELECT "2017" AS year, p.geo_id AS county,
         (p.poverty * 100.0 / p.pop_determined_poverty_status) AS poverty_rate
  FROM `sdoh`.`census_bureau_acs`.`county_2016_5yr` p
  WHERE p.pop_determined_poverty_status > 0

  UNION ALL

  SELECT "2018" AS year, p.geo_id AS county,
         (p.poverty * 100.0 / p.pop_determined_poverty_status) AS poverty_rate
  FROM `sdoh`.`census_bureau_acs`.`county_2017_5yr` p
  WHERE p.pop_determined_poverty_status > 0
),

joined AS (
  SELECT
    n.year,
    c.poverty_rate AS x,
    (n.births_without_morbidity * 100.0 / n.total_births) AS y
  FROM natality_agg n
  JOIN census c
    ON n.year = c.year
   AND n.county = c.county
)

SELECT
  year AS data_year,

  (
    COUNT(*) * SUM(x * y) - SUM(x) * SUM(y)
  ) /
  SQRT(
    (COUNT(*) * SUM(x * x) - POWER(SUM(x), 2)) *
    (COUNT(*) * SUM(y * y) - POWER(SUM(y), 2))
  ) AS correlation_coefficient

FROM joined
GROUP BY year
ORDER BY year;