WITH MomentumTrades AS (
    SELECT
        AVG(t.StrikePrice - t.LastPx) AS avgMomentum
    FROM CYMBAL_INVESTMENTS.cymbal_investments.trade_capture_report AS t
    UNNEST t.Sides AS s
    WHERE SUBSTR(t.TargetCompID, 0, 4) = "MOMO"
      AND s.Side = "LONG"
),

FeelingLuckyTrades AS (
    SELECT
        AVG(t.StrikePrice - t.LastPx) AS avgLucky
    FROM CYMBAL_INVESTMENTS.cymbal_investments.trade_capture_report AS t
    UNNEST t.Sides AS s
    WHERE SUBSTR(t.TargetCompID, 0, 4) = "LUCK"
      AND s.Side = "LONG"
)

SELECT
    f.avgLucky - m.avgMomentum AS averageDifference
FROM MomentumTrades AS m, FeelingLuckyTrades AS f;