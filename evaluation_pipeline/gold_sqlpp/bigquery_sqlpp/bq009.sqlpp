WITH all_sessions AS (
    SELECT s.`date`, s.trafficSource.source AS source, s.totals.totalTransactionRevenue AS revenue
    FROM ga360.google_analytics_sample.ga_sessions_201701 s
    UNION ALL
    SELECT s.`date`, s.trafficSource.source AS source, s.totals.totalTransactionRevenue AS revenue
    FROM ga360.google_analytics_sample.ga_sessions_201702 s
    UNION ALL
    SELECT s.`date`, s.trafficSource.source AS source, s.totals.totalTransactionRevenue AS revenue
    FROM ga360.google_analytics_sample.ga_sessions_201703 s
    UNION ALL
    SELECT s.`date`, s.trafficSource.source AS source, s.totals.totalTransactionRevenue AS revenue
    FROM ga360.google_analytics_sample.ga_sessions_201704 s
    UNION ALL
    SELECT s.`date`, s.trafficSource.source AS source, s.totals.totalTransactionRevenue AS revenue
    FROM ga360.google_analytics_sample.ga_sessions_201705 s
    UNION ALL
    SELECT s.`date`, s.trafficSource.source AS source, s.totals.totalTransactionRevenue AS revenue
    FROM ga360.google_analytics_sample.ga_sessions_201706 s
    UNION ALL
    SELECT s.`date`, s.trafficSource.source AS source, s.totals.totalTransactionRevenue AS revenue
    FROM ga360.google_analytics_sample.ga_sessions_201707 s
    UNION ALL
    SELECT s.`date`, s.trafficSource.source AS source, s.totals.totalTransactionRevenue AS revenue
    FROM ga360.google_analytics_sample.ga_sessions_201708 s
),

MONTHLY_REVENUE AS (
    SELECT
        SUBSTR(a.`date`, 0, 6) AS month,
        a.source,
        ROUND(SUM(a.revenue) / 1000000, 2) AS revenue
    FROM all_sessions a
    GROUP BY SUBSTR(a.`date`, 0, 6), a.source
),

YEARLY_REVENUE AS (
    SELECT
        m.source,
        SUM(m.revenue) AS total_revenue
    FROM MONTHLY_REVENUE m
    GROUP BY m.source
),

TOP_SOURCE AS (
    SELECT RAW y.source
    FROM YEARLY_REVENUE y
    ORDER BY y.total_revenue DESC
    LIMIT 1
),

SOURCE_MONTHLY_REVENUE AS (
    SELECT
        m.month,
        m.source,
        m.revenue
    FROM MONTHLY_REVENUE m
    WHERE m.source IN TOP_SOURCE
),

REVENUE_DIFF AS (
    SELECT
        s.source,
        ROUND(MAX(s.revenue) - MIN(s.revenue), 2) AS diff_revenue
    FROM SOURCE_MONTHLY_REVENUE s
    GROUP BY s.source
)

SELECT
    r.source,
    r.diff_revenue
FROM REVENUE_DIFF r;
