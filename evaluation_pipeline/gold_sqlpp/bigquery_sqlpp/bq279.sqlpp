SELECT
    t.year AS year,
    COUNT(DISTINCT CASE WHEN s.status = 'active' THEN s.station_id END)
        AS number_status_active,
    COUNT(DISTINCT CASE WHEN s.status = 'closed' THEN s.station_id END)
        AS number_status_closed
FROM (
    SELECT
        DATE_PART_STR(tr.start_time, 'year') AS year,
        tr.start_station_id
    FROM austin.austin_bikeshare.bikeshare_trips tr
    WHERE DATE_PART_STR(tr.start_time, 'year') IN [2013, 2014]
) AS t
JOIN austin.austin_bikeshare.bikeshare_stations AS s
  ON t.start_station_id = s.station_id
GROUP BY t.year
ORDER BY t.year;
