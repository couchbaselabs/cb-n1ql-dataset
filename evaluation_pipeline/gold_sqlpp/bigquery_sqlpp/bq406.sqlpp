SELECT
    (SUM(CASE WHEN r.report_year = 2022 THEN r.race_asian ELSE 0 END)
     - SUM(CASE WHEN r.report_year = 2014 THEN r.race_asian ELSE 0 END))
    / SUM(CASE WHEN r.report_year = 2014 THEN r.race_asian ELSE 0 END) AS race_asian_growth,

    (SUM(CASE WHEN r.report_year = 2022 THEN r.race_black ELSE 0 END)
     - SUM(CASE WHEN r.report_year = 2014 THEN r.race_black ELSE 0 END))
    / SUM(CASE WHEN r.report_year = 2014 THEN r.race_black ELSE 0 END) AS race_black_growth,

    (SUM(CASE WHEN r.report_year = 2022 THEN r.race_hispanic_latinx ELSE 0 END)
     - SUM(CASE WHEN r.report_year = 2014 THEN r.race_hispanic_latinx ELSE 0 END))
    / SUM(CASE WHEN r.report_year = 2014 THEN r.race_hispanic_latinx ELSE 0 END) AS race_hispanic_growth,

    (SUM(CASE WHEN r.report_year = 2022 THEN r.race_native_american ELSE 0 END)
     - SUM(CASE WHEN r.report_year = 2014 THEN r.race_native_american ELSE 0 END))
    / SUM(CASE WHEN r.report_year = 2014 THEN r.race_native_american ELSE 0 END) AS race_native_american_growth,

    (SUM(CASE WHEN r.report_year = 2022 THEN r.race_white ELSE 0 END)
     - SUM(CASE WHEN r.report_year = 2014 THEN r.race_white ELSE 0 END))
    / SUM(CASE WHEN r.report_year = 2014 THEN r.race_white ELSE 0 END) AS race_white_growth,

    (SUM(CASE WHEN r.report_year = 2022 THEN r.gender_us_women ELSE 0 END)
     - SUM(CASE WHEN r.report_year = 2014 THEN r.gender_us_women ELSE 0 END))
    / SUM(CASE WHEN r.report_year = 2014 THEN r.gender_us_women ELSE 0 END) AS gender_us_women_growth,

    (SUM(CASE WHEN r.report_year = 2022 THEN r.gender_us_men ELSE 0 END)
     - SUM(CASE WHEN r.report_year = 2014 THEN r.gender_us_men ELSE 0 END))
    / SUM(CASE WHEN r.report_year = 2014 THEN r.gender_us_men ELSE 0 END) AS gender_us_men_growth,

    (SUM(CASE WHEN r.report_year = 2022 THEN r.gender_global_women ELSE 0 END)
     - SUM(CASE WHEN r.report_year = 2014 THEN r.gender_global_women ELSE 0 END))
    / SUM(CASE WHEN r.report_year = 2014 THEN r.gender_global_women ELSE 0 END) AS gender_global_women_growth,

    (SUM(CASE WHEN r.report_year = 2022 THEN r.gender_global_men ELSE 0 END)
     - SUM(CASE WHEN r.report_year = 2014 THEN r.gender_global_men ELSE 0 END))
    / SUM(CASE WHEN r.report_year = 2014 THEN r.gender_global_men ELSE 0 END) AS gender_global_men_growth

FROM google_dei.google_dei.dar_non_intersectional_representation r
WHERE r.report_year IN [2014, 2022]
  AND r.workforce = 'overall';
