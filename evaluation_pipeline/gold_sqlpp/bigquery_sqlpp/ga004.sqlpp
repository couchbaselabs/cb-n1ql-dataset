WITH UserInfo AS (
    SELECT
        T.user_pseudo_id,
        SUM(CASE WHEN T.event_name = "page_view" THEN 1 ELSE 0 END) AS page_view_count,
        SUM(CASE WHEN T.event_name IN ["in_app_purchase", "purchase"] THEN 1 ELSE 0 END) AS purchase_event_count
    FROM ga4.ga4_obfuscated_sample_ecommerce.events_202012 AS T
    WHERE T.event_date BETWEEN "20201201" AND "20201231"
    GROUP BY T.user_pseudo_id
),

Averages AS (
    SELECT
        (purchase_event_count > 0) AS purchaser,
        COUNT(*) AS user_count,
        SUM(page_view_count) AS total_page_views,
        SUM(page_view_count) / COUNT(*) AS avg_page_views
    FROM UserInfo
    GROUP BY (purchase_event_count > 0)
)

SELECT
    MAX(CASE WHEN purchaser THEN avg_page_views ELSE 0 END)
    -
    MAX(CASE WHEN NOT purchaser THEN avg_page_views ELSE 0 END)
    AS avg_page_views_difference
FROM Averages;