WITH visit AS (
    SELECT
        s.fullVisitorId AS fullvisitorid,
        MIN(s.`date`) AS date_first_visit
    FROM ga360.google_analytics_sample.ga_sessions_201702 s
    GROUP BY s.fullVisitorId
),

transactions AS (
    SELECT
        s.fullVisitorId AS fullvisitorid,
        MIN(s.`date`) AS date_transactions
    FROM ga360.google_analytics_sample.ga_sessions_201702 s
    UNNEST s.hits AS h
    WHERE h.`transaction`.transactionId IS NOT NULL
    GROUP BY s.fullVisitorId
),

device_transactions AS (
    SELECT DISTINCT
        s.fullVisitorId AS fullvisitorid,
        s.`date`,
        s.device.deviceCategory
    FROM ga360.google_analytics_sample.ga_sessions_201702 s
    UNNEST s.hits AS h
    WHERE h.`transaction`.transactionId IS NOT NULL
),

visits_transactions AS (
    SELECT
        v.fullvisitorid,
        v.date_first_visit,
        t.date_transactions,
        dt.deviceCategory AS device_transaction
    FROM visit v
    JOIN transactions t ON v.fullvisitorid = t.fullvisitorid
    JOIN device_transactions dt ON v.fullvisitorid = dt.fullvisitorid
        AND t.date_transactions = dt.`date`
)

SELECT
    vt.fullvisitorid,
    DATE_DIFF_STR(
        SUBSTR(vt.date_transactions, 0, 4) || "-" || SUBSTR(vt.date_transactions, 4, 2) || "-" || SUBSTR(vt.date_transactions, 6, 2),
        SUBSTR(vt.date_first_visit, 0, 4) || "-" || SUBSTR(vt.date_first_visit, 4, 2) || "-" || SUBSTR(vt.date_first_visit, 6, 2),
        "day"
    ) AS time,
    vt.device_transaction
FROM visits_transactions vt
ORDER BY vt.fullvisitorid;
