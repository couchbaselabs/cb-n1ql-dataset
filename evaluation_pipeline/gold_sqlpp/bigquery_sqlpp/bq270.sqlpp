WITH base AS (
    SELECT
        SUBSTR(s.date, 0, 6) AS month,
        h.eCommerceAction.action_type AS action_type
    FROM (
        SELECT date, hits FROM ga360.google_analytics_sample.ga_sessions_201701
        UNION ALL
        SELECT date, hits FROM ga360.google_analytics_sample.ga_sessions_201702
        UNION ALL
        SELECT date, hits FROM ga360.google_analytics_sample.ga_sessions_201703
    ) s
    UNNEST s.hits AS h
),

product_views AS (
    SELECT month, COUNT(1) AS num_product_view
    FROM base
    WHERE action_type = "2"
    GROUP BY month
),

add_to_cart AS (
    SELECT month, COUNT(1) AS num_addtocart
    FROM base
    WHERE action_type = "3"
    GROUP BY month
),

purchases AS (
    SELECT month, COUNT(1) AS num_purchase
    FROM base
    WHERE action_type = "6"
    GROUP BY month
)

SELECT
    pv.month,
    ROUND(atc.num_addtocart * 100.0 / pv.num_product_view, 6) AS add_to_cart_rate,
    ROUND(pur.num_purchase * 100.0 / pv.num_product_view, 6) AS purchase_rate
FROM product_views pv
LEFT JOIN add_to_cart atc ON pv.month = atc.month
LEFT JOIN purchases pur ON pv.month = pur.month
ORDER BY pv.month;