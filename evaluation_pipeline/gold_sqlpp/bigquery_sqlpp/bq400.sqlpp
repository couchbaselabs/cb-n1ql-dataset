WITH relevant_stop_times AS (
  SELECT st.trip_id, st.arrival_time, st.departure_time, st.stop_sequence,
         s.stop_name
  FROM san_francisco_plus.san_francisco_transit_muni.stop_times st
  JOIN san_francisco_plus.san_francisco_transit_muni.stops s
    ON TOSTRING(st.stop_id) = s.stop_id
  WHERE s.stop_name IN ['Clay St & Drumm St', 'Sacramento St & Davis St']
)
SELECT t.trip_headsign,
       MIN(st1.departure_time) AS EARLIEST_DEPARTURE,
       MAX(st2.arrival_time) AS LATEST_ARRIVAL
FROM san_francisco_plus.san_francisco_transit_muni.trips t
JOIN relevant_stop_times st1 ON TOSTRING(st1.trip_id) = t.trip_id AND st1.stop_name = 'Clay St & Drumm St'
JOIN relevant_stop_times st2 ON TOSTRING(st2.trip_id) = t.trip_id AND st2.stop_name = 'Sacramento St & Davis St'
WHERE st1.stop_sequence < st2.stop_sequence
GROUP BY t.trip_headsign;
