WITH visitor_pageviews AS (
    SELECT
        SUBSTR(s.`date`, 0, 6) AS month,
        CASE WHEN s.totals.transactions > 0 THEN "purchase" ELSE "non_purchase" END AS purchase_status,
        s.fullVisitorId,
        SUM(s.totals.pageviews) AS total_pageviews
    FROM ga360.google_analytics_sample.ga_sessions_201706 s
    WHERE s.totals.pageviews IS NOT NULL
    GROUP BY SUBSTR(s.`date`, 0, 6),
             CASE WHEN s.totals.transactions > 0 THEN "purchase" ELSE "non_purchase" END,
             s.fullVisitorId
    UNION ALL
    SELECT
        SUBSTR(s.`date`, 0, 6) AS month,
        CASE WHEN s.totals.transactions > 0 THEN "purchase" ELSE "non_purchase" END AS purchase_status,
        s.fullVisitorId,
        SUM(s.totals.pageviews) AS total_pageviews
    FROM ga360.google_analytics_sample.ga_sessions_201707 s
    WHERE s.totals.pageviews IS NOT NULL
    GROUP BY SUBSTR(s.`date`, 0, 6),
             CASE WHEN s.totals.transactions > 0 THEN "purchase" ELSE "non_purchase" END,
             s.fullVisitorId
),
avg_pageviews AS (
    SELECT
        vp.month,
        vp.purchase_status,
        AVG(vp.total_pageviews) AS avg_pageviews_per_visitor
    FROM visitor_pageviews vp
    GROUP BY vp.month, vp.purchase_status
)
SELECT
    ap.month,
    MAX(CASE WHEN ap.purchase_status = "purchase" THEN ap.avg_pageviews_per_visitor END) AS avg_pageviews_purchase,
    MAX(CASE WHEN ap.purchase_status = "non_purchase" THEN ap.avg_pageviews_per_visitor END) AS avg_pageviews_non_purchase
FROM avg_pageviews ap
GROUP BY ap.month
ORDER BY ap.month;
