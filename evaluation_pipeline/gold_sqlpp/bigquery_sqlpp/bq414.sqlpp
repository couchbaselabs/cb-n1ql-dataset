SELECT
    a.object_id,
    a.title,
    MILLIS_TO_STR(STR_TO_MILLIS(a.metadata_date), "1111-11-11") AS formatted_metadata_date
FROM the_met.the_met.objects AS a

JOIN the_met.the_met.vision_api_data AS v
ON a.object_id = v.object_id

UNNEST v.cropHintsAnnotation.cropHints AS ch

WHERE a.department = "The Libraries"
  AND ch.confidence > 0.5
  AND LOWER(a.title) LIKE "%book%";