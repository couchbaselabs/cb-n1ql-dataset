SELECT
    g.country_name,
    g.net_migration
FROM `census_bureau_international`.`census_bureau_international`.`birth_death_growth_rates` AS g
JOIN `census_bureau_international`.`census_bureau_international`.`country_names_area` AS a
ON g.country_code = a.country_code

WHERE g.year = 2017
  AND TO_NUMBER(a.country_area) > 500   
ORDER BY g.net_migration DESC

LIMIT 3;