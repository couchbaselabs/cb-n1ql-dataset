WITH berkeley_stations AS (
  SELECT s.station_id
  FROM san_francisco_plus.san_francisco_bikeshare.bikeshare_station_info s
  JOIN san_francisco_plus.san_francisco_bikeshare.bikeshare_regions r ON s.region_id = r.region_id
  WHERE r.name = 'Berkeley'
)
SELECT ROUND(
  (2 * 6371000 * ASIN(SQRT(
    POWER(SIN(RADIANS(t.end_station_latitude - t.start_station_latitude) / 2), 2)
    + COS(RADIANS(t.start_station_latitude)) * COS(RADIANS(t.end_station_latitude))
      * POWER(SIN(RADIANS(t.end_station_longitude - t.start_station_longitude) / 2), 2)
  ))) / t.duration_sec, 1
) AS HIGHEST_AVG_SPEED
FROM san_francisco_plus.san_francisco_bikeshare.bikeshare_trips t
JOIN berkeley_stations bs1 ON TOSTRING(t.start_station_id) = bs1.station_id
JOIN berkeley_stations bs2 ON TOSTRING(t.end_station_id) = bs2.station_id
WHERE t.start_station_latitude IS NOT NULL
  AND t.start_station_longitude IS NOT NULL
  AND t.end_station_latitude IS NOT NULL
  AND t.end_station_longitude IS NOT NULL
  AND t.duration_sec > 0
  AND (2 * 6371000 * ASIN(SQRT(
    POWER(SIN(RADIANS(t.end_station_latitude - t.start_station_latitude) / 2), 2)
    + COS(RADIANS(t.start_station_latitude)) * COS(RADIANS(t.end_station_latitude))
      * POWER(SIN(RADIANS(t.end_station_longitude - t.start_station_longitude) / 2), 2)
  ))) > 1000
ORDER BY HIGHEST_AVG_SPEED DESC
LIMIT 1;
